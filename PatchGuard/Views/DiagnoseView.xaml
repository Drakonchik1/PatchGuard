<UserControl x:Class="PatchGuard.Views.DiagnoseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PatchGuard.Controls"
             xmlns:models="clr-namespace:PatchGuard.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False">
        <Grid Style="{StaticResource PageRoot}">
            <StackPanel>
                <controls:PageHeader Title="Diagnose"
                                     Eyebrow="READ-ONLY CHECKS"
                                     Subtitle="Choose a scan based on what changed or what you want to investigate. No Windows settings are modified."/>
                <controls:JourneyStepIndicator CurrentStep="1"/>
                <ItemsControl ItemsSource="{Binding Scenarios}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ScenarioOption}">
                            <Button Style="{StaticResource TileButton}"
                                    Width="300"
                                    MinHeight="168"
                                    Margin="0,0,14,14"
                                    Command="{Binding DataContext.StartScanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    AutomationProperties.Name="{Binding Title}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource SubtleText}" FontSize="13"/>
                                    <TextBlock Text="Start read-only scan →"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"
                                               Margin="0,16,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
