<UserControl x:Class="PatchGuard.Views.FpsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             xmlns:entities="clr-namespace:PatchGuard.Data.Entities"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="///" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock Text="Game FPS" Style="{StaticResource HeadingText}" Margin="0"/>
                </StackPanel>
                <TextBlock Text="Measure real in-game frame rate (Average / 1% low / 0.1% low) with Intel PresentMon."
                           Style="{StaticResource SubtleText}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="380"/>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="320" MaxWidth="360"/>
                </Grid.ColumnDefinitions>

                <!-- Left: capture controls + result -->
                <StackPanel Grid.Column="0">
                    <!-- Not available notice -->
                    <Border Style="{StaticResource CardBorder}" BorderBrush="{StaticResource WarnBrush}"
                            Visibility="{Binding IsAvailable, Converter={StaticResource InverseBool}}">
                        <StackPanel>
                            <TextBlock Text="PresentMon not installed" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardPanel}">
                        <StackPanel>
                            <TextBlock Text="Capture" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="Game / application" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Processes}"
                                          SelectedItem="{Binding SelectedProcess}"
                                          DisplayMemberPath="Display"
                                          Height="36" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="Refresh" Margin="12,0,0,0"
                                        Style="{StaticResource SecondaryButton}" Command="{Binding RefreshProcessesCommand}"/>
                            </Grid>

                            <TextBlock Text="Duration (seconds)" Style="{StaticResource MetricLabel}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding SecondsOptions}" SelectedItem="{Binding SelectedSeconds}"
                                      Width="120" HorizontalAlignment="Left" Height="36" VerticalContentAlignment="Center" Margin="0,0,0,18"/>

                            <Button Content="Start capture" HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryButtonInteractive}" Command="{Binding CaptureCommand}"/>

                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}" Margin="0,16,0,0"
                                       Visibility="{Binding IsAvailable, Converter={StaticResource BoolVis}}"/>

                            <Button Content="Run as admin (needed to capture other apps)" HorizontalAlignment="Left" Margin="0,16,0,0"
                                    Style="{StaticResource SecondaryButton}" Command="{Binding RunAsAdminCommand}"
                                    Visibility="{Binding IsElevated, Converter={StaticResource InverseBool}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Result -->
                    <Border Style="{StaticResource DashboardPanel}"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Result" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{Binding ResultTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,18"/>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="AVERAGE" Style="{StaticResource StatCaption}"/>
                                    <TextBlock Text="{Binding AverageFpsText}" Style="{StaticResource StatBig}" Foreground="{StaticResource GoodBrush}"/>
                                    <TextBlock Text="FPS" Style="{StaticResource SubtleText}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="1% LOW" Style="{StaticResource StatCaption}"/>
                                    <TextBlock Text="{Binding OnePercentLowText}" Style="{StaticResource StatBig}" Foreground="{StaticResource WarnBrush}"/>
                                    <TextBlock Text="FPS" Style="{StaticResource SubtleText}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="0.1% LOW" Style="{StaticResource StatCaption}"/>
                                    <TextBlock Text="{Binding PointOnePercentLowText}" Style="{StaticResource StatBig}" Foreground="{StaticResource CriticalBrush}"/>
                                    <TextBlock Text="FPS" Style="{StaticResource SubtleText}" FontSize="12"/>
                                </StackPanel>
                            </UniformGrid>
                            <TextBlock Text="{Binding ResultDetail}" Style="{StaticResource SubtleText}" FontSize="12" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: history -->
                <Border Grid.Column="2" Style="{StaticResource DashboardPanel}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Recent captures" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding RecentCaptures}"
                                      Visibility="{Binding HasHistory, Converter={StaticResource BoolVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type entities:FpsCaptureRecord}">
                                    <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <TextBlock Text="{Binding ProcessName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CapturedAt, StringFormat='{}{0:g}'}" HorizontalAlignment="Right" Style="{StaticResource MetricLabel}"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="Avg" Style="{StaticResource MetricLabel}"/>
                                                <TextBlock Text="{Binding AverageFps, StringFormat='{}{0:F0} FPS'}" Style="{StaticResource MetricValue}" Foreground="{StaticResource GoodBrush}"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="1% low" Style="{StaticResource MetricLabel}"/>
                                                <TextBlock Text="{Binding OnePercentLowFps, StringFormat='{}{0:F0} FPS'}" Style="{StaticResource MetricValue}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="20"
                                Visibility="{Binding HasHistory, Converter={StaticResource InverseBool}}">
                            <TextBlock Text="No captures yet. Pick a running game and start a capture."
                                       Style="{StaticResource SubtleText}" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
