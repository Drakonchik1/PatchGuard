<UserControl x:Class="PatchGuard.Views.OptimizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PatchGuard.Controls"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             xmlns:entities="clr-namespace:PatchGuard.Data.Entities"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:OptimizationStatusConverter x:Key="OptStatus"/>
        <conv:OptimizationStatusToBrushConverter x:Key="OptStatusBrush"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:PageHeader Grid.Row="0"
                             Title="Optimize"
                             Eyebrow="SAFE ACTIONS"
                             Subtitle="One-click safe boost. Frees RAM and clears junk — no Windows settings are changed, nothing needs admin."/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <WrapPanel>

                <!-- Left: action + steps -->
                <StackPanel Width="420" Margin="0,0,16,0">
                    <Border Style="{StaticResource DashboardPanel}">
                        <StackPanel>
                            <Grid Margin="0,0,0,18">
                                <TextBlock Text="Boost steps" Style="{StaticResource SectionHeader}" Margin="0"/>
                                <Button HorizontalAlignment="Right" Content="Optimize now"
                                        Style="{StaticResource PrimaryButtonInteractive}" Command="{Binding OptimizeCommand}"/>
                            </Grid>

                            <CheckBox Content="Also restart Windows Explorer (taskbar blinks briefly)"
                                      Style="{StaticResource OptionCheckBox}" Margin="0,0,0,18"
                                      IsChecked="{Binding IncludeExplorerRestart}"
                                      IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}"/>

                            <ItemsControl ItemsSource="{Binding Steps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:OptimizationStepResult}">
                                        <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="18" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,18,0">
                                                    <TextBlock Text="{Binding StepName}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource SubtleText}" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Status, Converter={StaticResource OptStatus}}"
                                                               Foreground="{Binding Status, Converter={StaticResource OptStatusBrush}}"
                                                               FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding FreedDisplay}" Style="{StaticResource MetricLabel}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource SubtleText}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: history -->
                <StackPanel Width="420">
                    <controls:StatusSummaryCard Caption="RECLAIMED"
                                                Value="{Binding TotalFreedText}"
                                                SupportingText="Reported after the latest optimization run."
                                                StatusBrush="{StaticResource GoodBrush}"
                                                Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}"
                                                AutomationProperties.Name="Reclaimed storage summary"/>
                <Border Style="{StaticResource DashboardPanel}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Recent boosts" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding RecentRuns}"
                                      Visibility="{Binding HasHistory, Converter={StaticResource BoolVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type entities:OptimizationRunRecord}">
                                    <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RanAt, StringFormat='{}{0:g}'}" Style="{StaticResource MetricLabel}" Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding Summary}" Style="{StaticResource SubtleText}" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="20"
                                Visibility="{Binding HasHistory, Converter={StaticResource InverseBool}}">
                            <TextBlock Text="No boosts yet. Click Optimize now to free memory and clear junk."
                                       Style="{StaticResource SubtleText}" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                </StackPanel>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
