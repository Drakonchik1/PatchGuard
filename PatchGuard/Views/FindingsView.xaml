<UserControl x:Class="PatchGuard.Views.FindingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PatchGuard.Controls"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <conv:SeverityToBrushConverter x:Key="SeverityBrush"/>
        <conv:SeverityToBarBrushConverter x:Key="BarBrush"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:PageHeader Grid.Row="0"
                             Title="{Binding ScenarioTitle}"
                             Eyebrow="SCAN RESULTS"
                             Subtitle="Review measured system signals before generating a repair guide."/>

        <controls:JourneyStepIndicator Grid.Row="1" CurrentStep="3"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <WrapPanel>
                <controls:StatusSummaryCard Width="420"
                                            Caption="HEALTH INDEX"
                                            Value="{Binding HealthScore, StringFormat='{}{0} / 100'}"
                                            SupportingText="{Binding WarningCount, StringFormat='Warnings requiring review: {0}'}"
                                            StatusBrush="{StaticResource AccentBrush}"
                                            AutomationProperties.Name="Scan health summary"/>

                <Border Width="420" Style="{StaticResource DashboardPanel}" VerticalAlignment="Top" Margin="0,0,16,28">
                    <StackPanel>
                        <TextBlock Text="System usage" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding ScanMetrics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ScanMetric}">
                                    <StackPanel Margin="0,0,0,22">
                                        <Grid>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding Value}" Style="{StaticResource MetricValue}"/>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource AccentProgressBar}"
                                                     Maximum="100" Value="{Binding BarPercent}"
                                                     Foreground="{Binding Severity, Converter={StaticResource BarBrush}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Width="420" Style="{StaticResource DashboardPanel}">
                    <StackPanel>
                        <TextBlock Text="Findings detail" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding Findings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Finding}">
                                    <Border Background="#1E1E24" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,6,12,0" VerticalAlignment="Top"
                                                             Fill="{Binding Severity, Converter={StaticResource SeverityBrush}}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ModuleName}" HorizontalAlignment="Right"
                                                           Style="{StaticResource MetricLabel}" Margin="12,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Severity, StringFormat='Severity: {0}'}"
                                                       Style="{StaticResource MetricLabel}" Margin="0,0,0,10"/>
                                            <TextBlock Text="Explanation" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap"
                                                       Style="{StaticResource SubtleText}" FontSize="13" LineHeight="20"
                                                       Margin="0,4,0,12"/>
                                            <TextBlock Text="Evidence" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Evidence}" TextWrapping="Wrap"
                                                       Style="{StaticResource SubtleText}" Margin="0,4,0,12"/>
                                            <TextBlock Text="Recommended fix" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding RecommendedFix}" TextWrapping="Wrap"
                                                       Style="{StaticResource SubtleText}" Margin="0,4,0,12"/>
                                            <WrapPanel>
                                                <TextBlock Text="{Binding ActionState, StringFormat='Action state: {0}'}"
                                                           Style="{StaticResource MetricLabel}" Margin="0,0,18,6"/>
                                                <TextBlock Text="{Binding AdminRequirement, StringFormat='Admin requirement: {0}'}"
                                                           Style="{StaticResource MetricLabel}" Margin="0,0,18,6"/>
                                                <TextBlock Text="{Binding Risk, StringFormat='Risk: {0}'}"
                                                           Style="{StaticResource MetricLabel}" Margin="0,0,18,6"/>
                                                <TextBlock Text="{Binding VerificationStatus, StringFormat='Verification status: {0}'}"
                                                           Style="{StaticResource MetricLabel}" Margin="0,0,18,6"/>
                                            </WrapPanel>
                                            <TextBlock Text="Source: Local diagnostic data"
                                                       Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
            <Button Content="Choose another scan" Style="{StaticResource SecondaryButton}" Command="{Binding GoBackCommand}" Margin="0,0,16,0"
                    AutomationProperties.Name="Return to scan choices"/>
            <Button Content="Open optional AI guidance" Style="{StaticResource PrimaryButtonInteractive}" Command="{Binding GetRepairGuideCommand}"
                    AutomationProperties.Name="Open optional AI guidance without generating it"/>
        </StackPanel>
    </Grid>
</UserControl>
