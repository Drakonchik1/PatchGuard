<UserControl x:Class="PatchGuard.Views.FindingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <conv:SeverityToBrushConverter x:Key="SeverityBrush"/>
        <conv:SeverityToBarBrushConverter x:Key="BarBrush"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,40">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="///" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding ScenarioTitle}" Style="{StaticResource HeadingText}" Margin="0"/>
                </StackPanel>
                <TextBlock Style="{StaticResource SubtleText}">
                    <Run Text="{Binding Findings.Count, Mode=OneWay}"/><Run Text=" signals · "/>
                    <Run Text="{Binding WarningCount, Mode=OneWay}"/><Run Text=" warnings"/>
                </TextBlock>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,0,0">
                <TextBlock Text="Health index" Style="{StaticResource MetricLabel}" HorizontalAlignment="Right" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding HealthScore}" FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource DashboardPanel}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="System usage" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding ScanMetrics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ScanMetric}">
                                    <StackPanel Margin="0,0,0,22">
                                        <Grid>
                                            <TextBlock Text="{Binding Label}" Style="{StaticResource MetricLabel}"/>
                                            <TextBlock Text="{Binding Value}" Style="{StaticResource MetricValue}"/>
                                        </Grid>
                                        <ProgressBar Style="{StaticResource AccentProgressBar}"
                                                     Maximum="100" Value="{Binding BarPercent}"
                                                     Foreground="{Binding Severity, Converter={StaticResource BarBrush}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource DashboardPanel}">
                    <StackPanel>
                        <TextBlock Text="Findings detail" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding Findings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Finding}">
                                    <Border Background="#1E1E24" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,6,12,0" VerticalAlignment="Top"
                                                             Fill="{Binding Severity, Converter={StaticResource SeverityBrush}}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ModuleName}" HorizontalAlignment="Right"
                                                           Style="{StaticResource MetricLabel}" Margin="12,0,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Details}" TextWrapping="Wrap"
                                                       Style="{StaticResource SubtleText}" FontSize="13" LineHeight="20"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
            <Button Content="Back" Style="{StaticResource SecondaryButton}" Command="{Binding GoBackCommand}" Margin="0,0,16,0"/>
            <Button Content="Convene AI council" Style="{StaticResource PrimaryButton}" Command="{Binding GetRepairGuideCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
