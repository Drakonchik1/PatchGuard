<UserControl x:Class="PatchGuard.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PatchGuard.Controls"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640"
             d:DesignWidth="920">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False">
        <Grid Style="{StaticResource PageRoot}">
            <StackPanel>
                <controls:PageHeader Title="Dashboard"
                                     Eyebrow="SYSTEM OVERVIEW"
                                     Subtitle="Choose the next task, review your latest health result, or take a one-time hardware snapshot."/>

                <TextBlock Text="{Binding MachineLabel, StringFormat='Machine: {0}'}"
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,18"/>

                <Border Style="{StaticResource ErrorCard}"
                        Visibility="{Binding HasDashboardError, Converter={StaticResource BoolVis}}"
                        AutomationProperties.LiveSetting="Polite"
                        AutomationProperties.Name="Dashboard error">
                    <TextBlock Text="{Binding DashboardErrorMessage}" TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="Current status" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="0,0,0,14">
                    <controls:StatusSummaryCard Width="220"
                                                Caption="LATEST HEALTH"
                                                Value="{Binding LatestHealthText}"
                                                SupportingText="{Binding LatestScanSummary}"
                                                StatusBrush="{StaticResource AccentBrush}"
                                                AutomationProperties.Name="Latest health summary"/>
                    <controls:StatusSummaryCard Width="220"
                                                Caption="CPU LOAD"
                                                Value="{Binding CpuLoadText}"
                                                SupportingText="{Binding HardwareStatusText}"
                                                StatusBrush="{StaticResource InfoBrush}"
                                                AutomationProperties.Name="CPU snapshot summary"/>
                    <controls:StatusSummaryCard Width="220"
                                                Caption="MEMORY"
                                                Value="{Binding MemoryText}"
                                                SupportingText="{Binding HardwareStatusText}"
                                                StatusBrush="{StaticResource GoodBrush}"
                                                AutomationProperties.Name="Memory snapshot summary"/>
                </WrapPanel>

                <Border Style="{StaticResource DashboardPanel}"
                        AutomationProperties.Name="Recommended action">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Recommended next action" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RecommendedAction}" Style="{StaticResource SubtleText}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Run quick scan"
                                Style="{StaticResource PrimaryButtonInteractive}"
                                Command="{Binding StartScanCommand}"
                                CommandParameter="{Binding Scenarios[3]}"
                                AutomationProperties.Name="Run quick health scan"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="Start a diagnostic scan" Style="{StaticResource SectionHeader}"/>
                <ItemsControl ItemsSource="{Binding Scenarios}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ScenarioOption}">
                            <Button Style="{StaticResource TileButton}"
                                    Width="300"
                                    MinHeight="150"
                                    Margin="0,0,14,14"
                                    Command="{Binding DataContext.StartScanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    AutomationProperties.Name="{Binding Title}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource SubtleText}" FontSize="12"/>
                                    <TextBlock Text="Start scan →" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Recent health history" Style="{StaticResource SectionHeader}"/>
                <ItemsControl ItemsSource="{Binding RecentScans}"
                              Visibility="{Binding HasScanHistory, Converter={StaticResource BoolVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ScanHistoryEntry}">
                            <Border Style="{StaticResource CardBorder}"
                                    AutomationProperties.Name="{Binding ScenarioTitle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="{Binding ScenarioTitle}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ScannedAt, StringFormat='{}{0:g}'}" Style="{StaticResource SubtleText}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding HealthScore, StringFormat='Health {0}/100'}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding WarningCount, StringFormat='Warnings: {0}'}" Style="{StaticResource SubtleText}" FontSize="12" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Style="{StaticResource EmptyStateCard}"
                        Visibility="{Binding HasScanHistory, Converter={StaticResource InverseBool}}"
                        AutomationProperties.Name="No scan history">
                    <TextBlock Text="No scans saved yet. Run a diagnostic scan to create your first health baseline."
                               Style="{StaticResource SubtleText}"
                               TextAlignment="Center"/>
                </Border>

                <TextBlock Text="Quick access" Style="{StaticResource SectionHeader}"/>
                <WrapPanel>
                    <Button Content="Live Monitor"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,12"
                            AutomationProperties.Name="Open Live Monitor"
                            Command="{Binding OpenMonitorCommand}"/>
                    <Button Content="Game Performance"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,12"
                            AutomationProperties.Name="Open Game Performance"
                            Command="{Binding OpenGamePerformanceCommand}"/>
                    <Button Content="Optimize"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,12,12"
                            AutomationProperties.Name="Open Optimize"
                            Command="{Binding OpenOptimizeCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
