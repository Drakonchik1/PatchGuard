<UserControl x:Class="PatchGuard.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Style="{StaticResource PageRoot}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="///" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock Text="Home" Style="{StaticResource HeadingText}" Margin="0"/>
                </StackPanel>
                <TextBlock Style="{StaticResource SubtleText}" MaxWidth="640" HorizontalAlignment="Left">
                    <Run Text="Machine: "/>
                    <Run Text="{Binding MachineLabel, Mode=OneWay}" Foreground="#F2F2F7"/>
                </TextBlock>
                <TextBlock Text="Monitor temperatures and FPS, run a safe one-click boost, or scan for issues and get an AI council fix plan."
                           Style="{StaticResource SubtleText}" Margin="0,8,0,0" MaxWidth="640" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Feature tiles -->
            <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,36">
                <Button Style="{StaticResource TileButton}" Margin="0,0,16,0"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Monitor">
                    <StackPanel>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,14"/>
                        <TextBlock Text="Live monitor" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="CPU/GPU temperatures, load, and memory in real time." Style="{StaticResource SubtleText}" FontSize="13"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource TileButton}" Margin="0,0,16,0"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Fps">
                    <StackPanel>
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,14"/>
                        <TextBlock Text="Game FPS" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Measure Average / 1% low / 0.1% low frame rate." Style="{StaticResource SubtleText}" FontSize="13"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource TileButton}"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="Optimize">
                    <StackPanel>
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,14"/>
                        <TextBlock Text="Optimize" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="One-click safe boost: free RAM, clear junk, no settings changed." Style="{StaticResource SubtleText}" FontSize="13"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Scenarios + history -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="380"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="320" MaxWidth="380"/>
                </Grid.ColumnDefinitions>

                <!-- Scenarios -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Scan scenarios" Style="{StaticResource SectionHeader}"/>

                    <ItemsControl ItemsSource="{Binding Scenarios}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ScenarioOption}">
                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,24,0">
                                            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Style="{StaticResource SubtleText}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Start scan"
                                                Style="{StaticResource PrimaryButtonInteractive}"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.StartScanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Scan history -->
                <Border Grid.Column="2" Style="{StaticResource DashboardPanel}" VerticalAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="///" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" Margin="0,0,8,0"/>
                            <TextBlock Text="Scan history" Style="{StaticResource SectionHeader}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="Compare health over time — especially after Windows updates."
                                   Style="{StaticResource SubtleText}" Margin="0,0,0,24"/>

                        <ItemsControl ItemsSource="{Binding RecentScans}"
                                      Visibility="{Binding HasScanHistory, Converter={StaticResource BoolVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ScanHistoryEntry}">
                                    <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="18" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,14">
                                                <TextBlock Text="{Binding ScenarioTitle}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ScannedAt, StringFormat='{}{0:g}'}"
                                                           HorizontalAlignment="Right" Style="{StaticResource MetricLabel}"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Health" Style="{StaticResource MetricLabel}"/>
                                                <TextBlock Text="{Binding HealthScore}" Style="{StaticResource MetricValue}"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Warnings" Style="{StaticResource MetricLabel}"/>
                                                <TextBlock Text="{Binding WarningCount}" Style="{StaticResource MetricValue}"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="Trend" Style="{StaticResource MetricLabel}"/>
                                                <TextBlock Text="{Binding TrendLabel}" Style="{StaticResource MetricValue}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="{StaticResource InsetBackgroundBrush}" CornerRadius="6" Padding="24"
                                Visibility="{Binding HasScanHistory, Converter={StaticResource InverseBool}}">
                            <TextBlock Text="No scans saved yet. Run your first scan — history and trends appear here."
                                       Style="{StaticResource SubtleText}" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
