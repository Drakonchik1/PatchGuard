<UserControl x:Class="PatchGuard.Views.PlannedFeatureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PatchGuard.Controls">
    <Grid Style="{StaticResource PageRoot}">
        <StackPanel>
            <controls:PageHeader Title="{Binding Title}"
                                 Eyebrow="ROADMAP"
                                 Subtitle="This destination is available now so navigation remains predictable."/>
            <Border Style="{StaticResource EmptyStateCard}"
                    AutomationProperties.Name="{Binding Title}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="{Binding Message}" Style="{StaticResource SubtleText}"/>
                    <TextBlock Text="No controls are shown because this feature is not implemented yet."
                               Style="{StaticResource SubtleText}"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
