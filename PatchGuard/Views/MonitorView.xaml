<UserControl x:Class="PatchGuard.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PatchGuard.Converters"
             xmlns:models="clr-namespace:PatchGuard.Models"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="640" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:MetricBrushConverter x:Key="MetricBrush"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="///" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock Text="Live monitor" Style="{StaticResource HeadingText}" Margin="0"/>
                </StackPanel>
                <TextBlock Text="Real-time temperatures, load, and memory. Updates every 1.5 seconds."
                           Style="{StaticResource SubtleText}"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Style="{StaticResource PillBadge}"
                    Visibility="{Binding IsElevated, Converter={StaticResource BoolVis}}">
                <TextBlock Text="Administrator" Foreground="{StaticResource GoodBrush}" FontSize="12" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <!-- Monitor unavailable -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding MonitorUnavailable, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <TextBlock Text="Hardware monitoring unavailable" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubtleText}"/>
                    </StackPanel>
                </Border>

                <!-- Admin hint -->
                <Border Style="{StaticResource CardBorder}" BorderBrush="{StaticResource WarnBrush}"
                        Visibility="{Binding SensorsLimited, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Temperatures need administrator rights" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"/>
                            <TextBlock Text="Relaunch PatchGuard elevated to read CPU/GPU temperatures and fan speeds. Load and memory are shown either way."
                                       Style="{StaticResource SubtleText}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run as admin" VerticalAlignment="Center"
                                Style="{StaticResource PrimaryButtonInteractive}" Command="{Binding RunAsAdminCommand}"/>
                    </Grid>
                </Border>

                <!-- Big tiles -->
                <WrapPanel Orientation="Horizontal">
                    <!-- CPU -->
                    <Border Style="{StaticResource StatTile}" Width="320">
                        <StackPanel>
                            <TextBlock Text="PROCESSOR" Style="{StaticResource StatCaption}"/>
                            <TextBlock Text="{Binding CpuName}" Style="{StaticResource SubtleText}" Margin="0,2,0,14" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CpuTempText}" Style="{StaticResource StatBig}"
                                       Foreground="{Binding CpuTempPercent, Converter={StaticResource MetricBrush}, ConverterParameter=temp}"/>
                            <Grid Margin="0,14,0,4">
                                <TextBlock Text="Load" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding CpuLoadText}" Style="{StaticResource MetricValue}"/>
                            </Grid>
                            <ProgressBar Style="{StaticResource AccentProgressBar}" Maximum="100" Value="{Binding CpuLoadPercent}"
                                         Foreground="{Binding CpuLoadPercent, Converter={StaticResource MetricBrush}, ConverterParameter=load}"/>
                            <TextBlock Text="{Binding CpuExtraText}" Style="{StaticResource SubtleText}" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- GPU -->
                    <Border Style="{StaticResource StatTile}" Width="320">
                        <StackPanel>
                            <TextBlock Text="GRAPHICS" Style="{StaticResource StatCaption}"/>
                            <TextBlock Text="{Binding GpuName}" Style="{StaticResource SubtleText}" Margin="0,2,0,14" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding GpuTempText}" Style="{StaticResource StatBig}"
                                       Foreground="{Binding GpuTempPercent, Converter={StaticResource MetricBrush}, ConverterParameter=temp}"/>
                            <Grid Margin="0,14,0,4">
                                <TextBlock Text="Load" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding GpuLoadText}" Style="{StaticResource MetricValue}"/>
                            </Grid>
                            <ProgressBar Style="{StaticResource AccentProgressBar}" Maximum="100" Value="{Binding GpuLoadPercent}"
                                         Foreground="{Binding GpuLoadPercent, Converter={StaticResource MetricBrush}, ConverterParameter=load}"/>
                            <TextBlock Text="{Binding GpuExtraText}" Style="{StaticResource SubtleText}" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Style="{StaticResource StatTile}" Width="320">
                        <StackPanel>
                            <TextBlock Text="MEMORY" Style="{StaticResource StatCaption}"/>
                            <TextBlock Text="System RAM" Style="{StaticResource SubtleText}" Margin="0,2,0,14"/>
                            <TextBlock Text="{Binding RamText}" Style="{StaticResource StatBig}"/>
                            <Grid Margin="0,14,0,4">
                                <TextBlock Text="In use" Style="{StaticResource MetricLabel}"/>
                                <TextBlock Text="{Binding RamPercent, StringFormat='{}{0:F0} %'}" Style="{StaticResource MetricValue}"/>
                            </Grid>
                            <ProgressBar Style="{StaticResource AccentProgressBar}" Maximum="100" Value="{Binding RamPercent}"
                                         Foreground="{Binding RamPercent, Converter={StaticResource MetricBrush}, ConverterParameter=load}"/>
                            <TextBlock Text="{Binding RamDetailText}" Style="{StaticResource SubtleText}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Detailed sensors -->
                <Border Style="{StaticResource DashboardPanel}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Sensors" Style="{StaticResource SectionHeader}"/>
                        <ItemsControl ItemsSource="{Binding Sensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SensorReading}">
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource MetricLabel}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Hardware}" Style="{StaticResource MetricLabel}"
                                                   Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" Margin="12,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DisplayValue}" Style="{StaticResource MetricValue}" Margin="12,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No detailed sensors exposed. Run as administrator for temperatures and fan speeds."
                                   Style="{StaticResource SubtleText}" FontSize="12"
                                   Visibility="{Binding SensorsLimited, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
