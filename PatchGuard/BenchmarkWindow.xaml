<Window x:Class="PatchGuard.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Render test"
        Width="480"
        Height="320"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0C"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid>
        <Canvas x:Name="RenderCanvas" Background="#111114"/>
        <TextBlock Text="Measuring render FPS…"
                   Foreground="#8E8E93"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,16"/>
    </Grid>
</Window>
