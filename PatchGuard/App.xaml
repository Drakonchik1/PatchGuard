<Application x:Class="PatchGuard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PatchGuard.ViewModels"
             xmlns:views="clr-namespace:PatchGuard.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <views:HomeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DiagnoseViewModel}">
                <views:DiagnoseView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ScanViewModel}">
                <views:ScanView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FindingsViewModel}">
                <views:FindingsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GuideViewModel}">
                <views:GuideView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                <views:MonitorView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:FpsViewModel}">
                <views:FpsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OptimizeViewModel}">
                <views:OptimizeView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AlertsViewModel}">
                <views:PlannedFeatureView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:PlannedFeatureView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
