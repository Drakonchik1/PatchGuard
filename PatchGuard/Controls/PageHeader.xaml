<UserControl x:Class="PatchGuard.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsTabStop="False">
    <StackPanel Margin="0,0,0,24">
        <TextBlock Text="{Binding Eyebrow, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource EyebrowText}"/>
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource HeadingText}"/>
        <TextBlock Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Style="{StaticResource SubtleText}"
                   MaxWidth="720"
                   HorizontalAlignment="Left"/>
    </StackPanel>
</UserControl>
