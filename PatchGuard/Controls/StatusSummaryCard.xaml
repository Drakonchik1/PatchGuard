<UserControl x:Class="PatchGuard.Controls.StatusSummaryCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="180"
             IsTabStop="False">
    <Border Style="{StaticResource StatusSummaryCard}">
        <StackPanel>
            <TextBlock Text="{Binding Caption, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource StatCaption}"/>
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,8,0,6"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding SupportingText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource SubtleText}"
                       FontSize="12"/>
        </StackPanel>
    </Border>
</UserControl>
