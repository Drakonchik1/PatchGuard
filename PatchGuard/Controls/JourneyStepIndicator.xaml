<UserControl x:Class="PatchGuard.Controls.JourneyStepIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsTabStop="False"
             AutomationProperties.Name="Diagnostic journey progress">
    <ItemsControl x:Name="StepItems" Margin="0,0,0,24">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Padding="12,9"
                        Margin="0,0,10,8"
                        CornerRadius="6"
                        AutomationProperties.Name="{Binding AutomationName}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="Opacity" Value="0.78"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Number}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
