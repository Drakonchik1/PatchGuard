<Window x:Class="PatchGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PatchGuard.Converters"
        Title="PatchGuard"
        Height="800"
        Width="1180"
        MinHeight="560"
        MinWidth="860"
        Background="{StaticResource WindowBackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        KeyboardNavigation.TabNavigation="Cycle"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:StringEqualsConverter x:Key="StrEq"/>
    </Window.Resources>

    <DockPanel>
        <!-- Labeled primary navigation -->
        <Border DockPanel.Dock="Left"
                Width="224"
                Background="{StaticResource NavBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="22,24,22,22">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PatchGuard" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="SYSTEM HEALTH &amp; BOOST" FontSize="10" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <!-- Footer note -->
                <TextBlock DockPanel.Dock="Bottom" Margin="22,0,22,20"
                           Text="Diagnostics are read-only. Optimizations show every action."
                           TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"/>

                <StackPanel KeyboardNavigation.DirectionalNavigation="Contained">
                    <TextBlock Text="WORKSPACE" Style="{StaticResource NavGroupLabel}"/>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Dashboard"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=Dashboard, Mode=OneWay}">
                        <AccessText Text="_Dashboard"/>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Diagnose"
                                 Command="{Binding NavigateCommand}" CommandParameter="Diagnose"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=Diagnose, Mode=OneWay}">
                        <AccessText Text="D_iagnose"/>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Live Monitor"
                                 Command="{Binding NavigateCommand}" CommandParameter="LiveMonitor"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=LiveMonitor, Mode=OneWay}">
                        <AccessText Text="_Live Monitor"/>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Game Performance"
                                 Command="{Binding NavigateCommand}" CommandParameter="GamePerformance"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=GamePerformance, Mode=OneWay}">
                        <AccessText Text="_Game Performance"/>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Optimize"
                                 Command="{Binding NavigateCommand}" CommandParameter="Optimize"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=Optimize, Mode=OneWay}">
                        <AccessText Text="_Optimize"/>
                    </RadioButton>
                    <TextBlock Text="APPLICATION" Style="{StaticResource NavGroupLabel}" Margin="22,20,22,6"/>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Alerts"
                                 Command="{Binding NavigateCommand}" CommandParameter="Alerts"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=Alerts, Mode=OneWay}">
                        <AccessText Text="_Alerts"/>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavSidebarButton}"
                                 AutomationProperties.Name="Settings"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                 IsChecked="{Binding ActiveSection, Converter={StaticResource StrEq}, ConverterParameter=Settings, Mode=OneWay}">
                        <AccessText Text="_Settings"/>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content host -->
        <ContentControl Content="{Binding CurrentViewModel}"/>
    </DockPanel>
</Window>
